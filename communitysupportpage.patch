diff --git a/components/CommunityMap.tsx b/components/CommunityMap.tsx
new file mode 100644
index 0000000..84e11bb
--- /dev/null
+++ b/components/CommunityMap.tsx
@@ -0,0 +1,164 @@
+'use client';
+
+import { useEffect, useRef, useState } from 'react';
+import type { Map as LeafletMap, Marker } from 'leaflet';
+import 'leaflet/dist/leaflet.css';
+import { businesses, CAT_COLORS, type Business, type BusinessCategory } from '@/lib/communityBusinesses';
+import { PHONE_TEL } from '@/lib/dictionaries';
+
+type Filters = Record<'all' | BusinessCategory, string>;
+
+interface CommunityStrings {
+  searchPlaceholder: string;
+  resultsFoundOne: string;
+  resultsFoundMany: string;
+  filters: Filters;
+  mapNote: string;
+  addBusiness: string;
+}
+
+function formatResultsFound(t: CommunityStrings, n: number) {
+  const template = n === 1 ? t.resultsFoundOne : t.resultsFoundMany;
+  return template.replace('{n}', String(n));
+}
+
+const CATS: (keyof Filters)[] = ['all', 'realtor', 'lender', 'contractor', 'shop', 'auto', 'salon'];
+
+function matchesQuery(b: Business, q: string) {
+  if (!q) return true;
+  const hay = `${b.name} ${b.address} ${b.city} ${b.cat}`.toLowerCase();
+  return hay.includes(q.toLowerCase());
+}
+
+// Wraps the matched substring of the business name in <mark> so the
+// company name is always clearly visible while searching.
+function HighlightedName({ name, query }: { name: string; query: string }) {
+  if (!query) return <>{name}</>;
+  const idx = name.toLowerCase().indexOf(query.toLowerCase());
+  if (idx === -1) return <>{name}</>;
+  return (
+    <>
+      {name.slice(0, idx)}
+      <mark className="biz-match">{name.slice(idx, idx + query.length)}</mark>
+      {name.slice(idx + query.length)}
+    </>
+  );
+}
+
+export default function CommunityMap({ t }: { t: CommunityStrings }) {
+  const mapRef = useRef<HTMLDivElement>(null);
+  const mapInstance = useRef<LeafletMap | null>(null);
+  const markersRef = useRef<Marker[]>([]);
+  const [query, setQuery] = useState('');
+  const [activeCat, setActiveCat] = useState<keyof Filters>('all');
+
+  const filtered = businesses
+    .filter((b) => activeCat === 'all' || b.cat === activeCat)
+    .filter((b) => matchesQuery(b, query));
+
+  // Init map once on mount (client-only; Leaflet needs `window`).
+  useEffect(() => {
+    let cancelled = false;
+    import('leaflet').then((L) => {
+      if (cancelled || !mapRef.current || mapInstance.current) return;
+      const map = L.map(mapRef.current, { scrollWheelZoom: true }).setView([25.55, -80.55], 9);
+      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
+        attribution: '&copy; OpenStreetMap contributors',
+        maxZoom: 18,
+      }).addTo(map);
+      mapInstance.current = map;
+      renderMarkers(L, map);
+    });
+    return () => {
+      cancelled = true;
+      mapInstance.current?.remove();
+      mapInstance.current = null;
+    };
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, []);
+
+  // Re-render markers whenever the filtered set changes.
+  useEffect(() => {
+    if (!mapInstance.current) return;
+    import('leaflet').then((L) => renderMarkers(L, mapInstance.current!));
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [query, activeCat]);
+
+  function renderMarkers(L: typeof import('leaflet'), map: LeafletMap) {
+    markersRef.current.forEach((m) => map.removeLayer(m));
+    markersRef.current = [];
+    filtered.forEach((b) => {
+      const color = CAT_COLORS[b.cat];
+      const icon = L.divIcon({
+        className: '',
+        html: `<div style="width:16px;height:16px;border-radius:50%;background:${color};border:3px solid #fff;box-shadow:0 0 0 4px rgba(0,0,0,.15)"></div>`,
+        iconSize: [16, 16],
+        iconAnchor: [8, 8],
+      });
+      const marker = L.marker([b.lat, b.lng], { icon }).addTo(map);
+      marker.bindPopup(
+        `<b>${b.name}</b><br><span class="biz-cat-badge" style="background:${color}">${t.filters[b.cat]}</span><span class="biz-addr">${b.address}, ${b.city}</span><a class="biz-tel" href="tel:${b.tel.replace(/\D/g, '')}">📞 ${b.tel}</a>`
+      );
+      markersRef.current.push(marker);
+    });
+  }
+
+  function jumpTo(b: Business) {
+    if (!mapInstance.current) return;
+    mapInstance.current.setView([b.lat, b.lng], 13);
+    const idx = filtered.indexOf(b);
+    if (idx >= 0 && markersRef.current[idx]) markersRef.current[idx].openPopup();
+  }
+
+  return (
+    <div className="community-map-block">
+      <div className="community-toolbar">
+        <input
+          className="community-search"
+          type="text"
+          placeholder={t.searchPlaceholder}
+          value={query}
+          onChange={(e) => setQuery(e.target.value)}
+          aria-label={t.searchPlaceholder}
+        />
+      </div>
+      <div className="community-filters">
+        {CATS.map((cat) => (
+          <button
+            key={cat}
+            type="button"
+            className={activeCat === cat ? 'on' : ''}
+            onClick={() => setActiveCat(cat)}
+          >
+            {t.filters[cat]}
+          </button>
+        ))}
+      </div>
+      <p className="community-result-count">{formatResultsFound(t, filtered.length)}</p>
+      <div className="community-split">
+        <div className="community-list" role="list">
+          {filtered.map((b) => (
+            <div key={b.name} className="community-list-item" role="listitem" onClick={() => jumpTo(b)}>
+              <span className="biz-cat-badge" style={{ background: CAT_COLORS[b.cat] }}>{t.filters[b.cat]}</span>
+              <span className="biz-name"><HighlightedName name={b.name} query={query} /></span>
+              <span className="biz-addr">{b.address}, {b.city}</span>
+              <a className="biz-tel" href={`tel:${b.tel.replace(/\D/g, '')}`} onClick={(e) => e.stopPropagation()}>
+                📞 {b.tel}
+              </a>
+            </div>
+          ))}
+          {filtered.length === 0 && (
+            <p className="community-empty">No businesses match your search. Try a different name, address, or category.</p>
+          )}
+        </div>
+        <div ref={mapRef} className="community-map" />
+      </div>
+      <p className="community-map-note">{t.mapNote}</p>
+      <div className="community-add-biz">
+        <a href={`mailto:mkagency2020@hotmail.com?subject=${encodeURIComponent('Add my business to the Community Map')}`}>
+          {t.addBusiness}
+        </a>
+      </div>
+    </div>
+  );
+}
