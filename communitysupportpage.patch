+import Image from 'next/image';
+import { getDict, PHONE_TEL } from '@/lib/dictionaries';
+import CommunityMap from '@/components/CommunityMap';
+
+export async function generateMetadata({ params }: { params: { lang: string } }) {
+  const t = getDict(params.lang);
+  return {
+    title: t.community.metaTitle,
+    description: t.community.metaDesc,
+    alternates: {
+      canonical: `/${params.lang}/community`,
+      languages: { en: '/en/community', es: '/es/community', ru: '/ru/community' },
+    },
+  };
+}
+
+const QUIZ_EMOJI = ['🚗', '🏠', '🏢', '🐾', '⛵', '📋', '🏍️', '🤔'];
+
+export default function Community({ params }: { params: { lang: string } }) {
+  const t = getDict(params.lang);
+  const c = t.community;
+
+  return (
+    <main>
+      <section className="community-hero">
+        <div className="container">
+          <span className="badge">{c.eyebrow}</span>
+          <h1>{c.h1}</h1>
+          <p>{c.sub}</p>
+          <p className="quote-line">{c.quote}</p>
+        </div>
+      </section>
+
+      <section className="container">
+        <CommunityMap
+          t={{
+            searchPlaceholder: c.searchPlaceholder,
+            resultsFoundOne: c.resultsFoundOne,
+            resultsFoundMany: c.resultsFoundMany,
+            filters: c.filters,
+            mapNote: c.mapNote,
+            addBusiness: c.addBusiness,
+          }}
+        />
+      </section>
+
+      <section className="section container">
+        <div className="community-quiz-box">
+          <h3>{c.quizTitle}</h3>
+          <div className="community-qchips">
+            {c.quizChips.map((label: string, i: number) => (
+              <div className="community-qchip" key={label}>
+                <span className="em">{QUIZ_EMOJI[i]}</span>
+                {label}
+              </div>
+            ))}
+          </div>
+          <div className="community-qfoot">{c.quizFoot}</div>
+        </div>
+      </section>
+
+      <section className="section container">
+        <p className="kicker">{t.nav.community}</p>
+        <h2>{c.testimonialsTitle}</h2>
+        <div className="community-testis">
+          {c.testimonials.map((ti: { quote: string; name: string; city: string }) => (
+            <div className="community-ti" key={ti.name}>
+              <div className="stars">★★★★★</div>
+              <p>&ldquo;{ti.quote}&rdquo;</p>
+              <b>{ti.name}</b><br />
+              <small>{ti.city}</small>
+            </div>
+          ))}
+        </div>
+
+        <div className="community-agent-strip">
+          <Image src="/images/mikhail.jpg" alt="Mikhail Kozlov, licensed Florida insurance agent" width={64} height={64} />
+          <p><b>Mikhail Kozlov</b>, {c.agentLine}</p>
+          <a href={`tel:${PHONE_TEL}`}>{t.contact.callUs} · (305) 247-8877</a>
+        </div>
+
+        <p className="community-trademark">{c.trademarkFooter}</p>
+        <p className="community-compliance">{c.compliance}</p>
+      </section>
+    </main>
+  );
+}
